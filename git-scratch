#!/usr/bin/env bash

## git-scratch: An opinionated git workflow for random walker.
## Requires: (optional) git-sync
## Usage
##   git scratch
##     Prepare a scratch branch
##   git scratch <branch name>
##     Start cherry-picking commits from the scratch branch

set -euo pipefail

REMOTE=$(git remote | head -n 1)
if [ -z "$REMOTE" ]; then
	echo "No remote"
	exit -1
fi

BASE=$(git symbolic-ref --short "refs/remotes/$REMOTE/HEAD" || true)
if [ -z "$BASE" ]; then
	REMOTE_HEAD=$(git remote show "$REMOTE" | sed -n 's/\s*HEAD branch: //p')
	echo "Retry after setting default default base branch for $REMOTE:"
	echo "  git symbolic-ref refs/remotes/$REMOTE/HEAD refs/remotes/$REMOTE/$REMOTE_HEAD"
	exit -1
fi

git_scratch() {
	if which git-sync > /dev/null; then
		git sync
	else
		git remote update "$REMOTE"
	fi
	git switch scratch || git switch -c scratch
	local MERGE_BASE=$(git merge-base HEAD "$BASE")
	local BASE_REF=$(git rev-parse "$BASE")
	if [ "$MERGE_BASE" != "$BASE_REF" ]; then
		git rebase --autostash -i "$BASE"
	fi
}

git_scratch_fork() {
	local BRANCH="$1"
	git switch scratch
	git switch -c "$BRANCH"
	git rebase --autostash -i "$BASE"
}

if [ $# -eq 0 ]; then
	git_scratch
else
	git_scratch_fork "$1"
fi
